# 江西安威 AI 客服 — 环境变量配置
# 填入实际值后，在 Deno Deploy 控制台 Settings → Environment Variables 中设置

# DeepSeek API Key（必填）— 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 企业微信机器人 Webhook（通知用）
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key-here

# Server酱 SendKey（备用通知，可选）
# SERVERCHAN_SENDKEY=your-sendkey-here

# 每日预算上限（元），默认 5
DAILY_BUDGET_YUAN=5

# 线索管理页密码（可选，不设则无密码保护）
# ADMIN_PASSWORD=your-password

# CORS 允许来源（用 * 表示允许所有，生产环境建议设具体域名）
ALLOWED_ORIGIN=*
